# Copy this file to .env and fill in your values.
# These are passed as env vars to k6: k6 run -e BASE_URL=... flows/01-redemptions.js
# Or set them in your shell before running run-test.ps1

# ── API ───────────────────────────────────────────────────────────────────────
BASE_URL=https://your-api.example.com/api

# ── Test Account Pool ─────────────────────────────────────────────────────────
# Accounts will be generated as: {USER_PREFIX}{N}@{USER_EMAIL_DOMAIN}
# Example: testuser1@example.com, testuser2@example.com, ...
TEST_PASSWORD=YourTestPassword123!
USER_START=1
USER_END=100
USER_PREFIX=testuser
USER_EMAIL_DOMAIN=example.com

# ── k6 Binary (Windows) ───────────────────────────────────────────────────────
# Set this if k6 is not in your PATH
# K6_PATH=C:\Program Files\k6\k6.exe

# ── Stage ─────────────────────────────────────────────────────────────────────
# smoke | load | stress | spike
STAGE=smoke
